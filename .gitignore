# Local homelab values — credentials, tokens, stateful host overrides, and secrets.
# Topology such as private IPs, CIDRs, DNS records, and StorageClasses can be
# committed when it contains no credentials.
local.mk
infrastructure/ansible/inventory/hosts.local.yaml
infrastructure/ansible/vars/bmc-users.local.yaml
infrastructure/ansible/vars/homelab.local.yaml
infrastructure/ansible/vars/proxmox-api-users.local.yaml
infrastructure/ansible/vars/proxmox-api-tokens.local.generated
infrastructure/ansible/vars/proxmox-users.local.yaml
infrastructure/ad/directory.yaml
infrastructure/ad/directory.local.yaml
infrastructure/ad/dns.local.yaml
infrastructure/ironic/nodes/proxmox-nodes.yaml

# Kolla-Ansible — contains all OpenStack service passwords
infrastructure/kolla-ansible/passwords.yml
infrastructure/kolla-ansible/clouds.yaml
# Kolla-Ansible generated admin credentials
infrastructure/kolla-ansible/admin-openrc.sh
infrastructure/kolla-ansible/admin-openrc-system.sh
infrastructure/kolla-ansible/public-openrc.sh
infrastructure/kolla-ansible/public-openrc-system.sh
# Kolla-Ansible Python virtual environment
infrastructure/kolla-ansible/.venv/
# Kolla-Ansible runtime config rendered from local values
infrastructure/kolla-ansible/globals.yml
infrastructure/kolla-ansible/inventory/openstack-vm
infrastructure/kolla-ansible/config/ironic.conf
infrastructure/kolla-ansible/config/ironic/ipa.ipxe
# Ironic Python Agent deploy images — large binaries, downloaded by make kolla-ipa-images
infrastructure/kolla-ansible/config/ironic/ironic-agent*.kernel
infrastructure/kolla-ansible/config/ironic/ironic-agent*.initramfs

# Terraform state and local overrides
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
*.tfvars
!*.example.tfvars
!infrastructure/terraform/proxmox.shared.tfvars
!infrastructure/terraform/proxmox-smoke-vm/terraform.tfvars
!infrastructure/terraform/proxmox-ad-vms/terraform.tfvars
!infrastructure/terraform/proxmox-talos-vm/terraform.tfvars

# Packer local overrides
*.pkrvars.hcl
!*.example.pkrvars.hcl
infrastructure/packer/proxmox-windows-server/generated/

# kubeconfig fragments
*.kubeconfig

# Talos generated cluster material
infrastructure/talos/clusters/*/controlplane.yaml
infrastructure/talos/clusters/*/worker.yaml
infrastructure/talos/clusters/*/nodes/
infrastructure/talos/clusters/*/talosconfig
infrastructure/talos/clusters/*/secrets.yaml
infrastructure/talos/clusters/*/kubeconfig

# macOS
.DS_Store

# Editor
.idea/
.vscode/settings.json
*.swp
