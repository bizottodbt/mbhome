infrastructure/ansible/vars/homelab.local.yaml
infrastructure/ansible/vars/proxmox-users.local.yaml
infrastructure/ironic/nodes/proxmox-nodes.yaml

# Kolla-Ansible — contains all OpenStack service passwords
infrastructure/kolla-ansible/passwords.yml
infrastructure/kolla-ansible/clouds.yaml
# Kolla-Ansible generated admin credentials
infrastructure/kolla-ansible/admin-openrc.sh
infrastructure/kolla-ansible/admin-openrc-system.sh
infrastructure/kolla-ansible/public-openrc.sh
infrastructure/kolla-ansible/public-openrc-system.sh
# Kolla-Ansible Python virtual environment
infrastructure/kolla-ansible/.venv/
# Kolla-Ansible runtime config rendered from local values
